@model ListRowActionsModel

<div class="list-row-actions">
    <a asp-action="@Model.DetailsAction"
       asp-route-id="@Model.Id"
       class="btn btn-icon btn-icon-view"
       title="@SharedLocalizer["Btn.Details"]"
       aria-label="@SharedLocalizer["Btn.Details"]">
        <i class="bi bi-eye" aria-hidden="true"></i>
    </a>
    @if (Model.ShowEdit && User.IsInRole("Operator"))
    {
        <a asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn btn-icon btn-icon-edit"
           title="@SharedLocalizer["Btn.Edit"]"
           aria-label="@SharedLocalizer["Btn.Edit"]">
            <i class="bi bi-pencil" aria-hidden="true"></i>
        </a>
    }
    @if (Model.ShowDelete && User.IsInRole("Operator") && !string.IsNullOrWhiteSpace(Model.DeleteModalId))
    {
        <button type="button"
                class="btn btn-icon btn-icon-delete"
                data-bs-toggle="modal"
                data-bs-target="#@Model.DeleteModalId"
                title="@SharedLocalizer["Btn.Delete"]"
                aria-label="@SharedLocalizer["Btn.Delete"]">
            <i class="bi bi-trash" aria-hidden="true"></i>
        </button>
    }
</div>
