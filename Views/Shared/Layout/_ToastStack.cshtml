<div class="toast-stack" id="foToastStack" aria-live="polite" aria-atomic="true">
    @if (TempData["Error"] is string tempError)
    {
        <div class="toast toast-danger" role="alert" data-fo-toast>
            <div class="toast-body d-flex align-items-start gap-2">
                <i class="bi bi-exclamation-circle-fill" style="color:var(--fo-danger-text);"></i>
                <div class="flex-grow-1">@tempError</div>
                <button type="button" class="btn-close btn-close-white" style="font-size:.7rem;" data-fo-toast-close></button>
            </div>
        </div>
    }
    @if (TempData["Success"] is string tempSuccess)
    {
        <div class="toast toast-success" role="status" data-fo-toast>
            <div class="toast-body d-flex align-items-start gap-2">
                <i class="bi bi-check-circle-fill" style="color:var(--fo-success-text);"></i>
                <div class="flex-grow-1">@tempSuccess</div>
                <button type="button" class="btn-close btn-close-white" style="font-size:.7rem;" data-fo-toast-close></button>
            </div>
        </div>
    }
</div>
