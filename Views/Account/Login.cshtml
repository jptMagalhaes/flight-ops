@model FlightOps.Models.Forms.Account.LoginModel

@{
    Layout = "Layout/_AuthLayout";
    ViewData["Title"] = SharedLocalizer["Login.Title"];
    ViewData["CenterMain"] = true;
}

<div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-4">
        <div class="card auth-card">
            <div class="card-body">
                <h1 class="h4 mb-3">@SharedLocalizer["Login.Title"]</h1>

                <form asp-action="Login" method="post">
                    <input type="hidden" asp-for="ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" autofocus />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">@SharedLocalizer["Login.SubmitButton"]</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("Layout/_ValidationScriptsPartial");
    }
}
