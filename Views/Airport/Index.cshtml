@model IEnumerable<AirportModel>
@using FlightOps.Helpers

@{
    ViewData["Title"] = SharedLocalizer["Title.Airports"];
    List<AirportModel> airports = Model.ToList();
    int airportTotal = airports.Count;
}

@if (airportTotal == 0)
{
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 page-header">
        <h1 class="mb-0">@SharedLocalizer["Title.Airports"]</h1>
        @if (User.IsInRole("Operator"))
        {
            <a asp-action="Create" class="btn btn-primary">@SharedLocalizer["Btn.CreateNew"]</a>
        }
    </div>
    <div class="empty-state">
        <div class="empty-state-icon"><i class="bi bi-building"></i></div>
        <div class="empty-state-title">@SharedLocalizer["Empty.Airports.Title"]</div>
        <p class="empty-state-msg mb-0">@SharedLocalizer["Empty.Airports.Message"]</p>
        @if (User.IsInRole("Operator"))
        {
            <a asp-action="Create" class="btn btn-primary">@SharedLocalizer["Btn.CreateNew"]</a>
        }
    </div>
}
else
{
    <div data-fo-list-search data-fo-page-size="10">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 page-header">
            <h1 class="mb-0 d-flex align-items-center gap-2 flex-wrap">
                @SharedLocalizer["Title.Airports"]
                <span class="page-header-count" aria-label="@SharedLocalizer["Airports.TotalCount", airportTotal]">@airportTotal</span>
            </h1>
            <div class="page-header-actions">
                @await Html.PartialAsync("Lists/_ListSearchBar")
                @if (User.IsInRole("Operator"))
                {
                    <a asp-action="Create" class="btn btn-primary">@SharedLocalizer["Btn.CreateNew"]</a>
                }
            </div>
        </div>
        <div class="table-responsive">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>@SharedLocalizer["Col.Name"]</th>
                    <th>@SharedLocalizer["Col.City"]</th>
                    <th>@SharedLocalizer["Col.Country"]</th>
                    <th>@SharedLocalizer["Col.IATA"]</th>
                    <th>@SharedLocalizer["Col.Latitude"]</th>
                    <th>@SharedLocalizer["Col.Longitude"]</th>
                    <th class="text-end">@SharedLocalizer["Col.Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (AirportModel airport in airports)
                {
                    <tr>
                        <td><span class="list-cell-primary">@airport.Name</span></td>
                        <td><span class="list-cell-secondary">@airport.City</span></td>
                        <td><span class="list-cell-meta">@airport.Country</span></td>
                        <td>
                            @await Html.PartialAsync("Lists/_ListAirportCell", new ListAirportCellModel { Iata = airport.IATA })
                        </td>
                        <td>
                            @await Html.PartialAsync("Lists/_ListMetric", new ListMetricModel
                            {
                                Value = NumberFormatHelper.Invariant(airport.Latitude),
                                Unit = "°"
                            })
                        </td>
                        <td>
                            @await Html.PartialAsync("Lists/_ListMetric", new ListMetricModel
                            {
                                Value = NumberFormatHelper.Invariant(airport.Longitude),
                                Unit = "°"
                            })
                        </td>
                        <td class="text-end">
                            @await Html.PartialAsync("Lists/_ListRowActions", new ListRowActionsModel
                            {
                                Id = airport.Id,
                                DeleteModalId = $"delAirportModal-{airport.Id}"
                            })

                            <div class="modal fade" id="delAirportModal-@airport.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content">
                                        <div class="modal-body p-4">
                                            <div class="modal-icon-box"><i class="bi bi-trash3"></i></div>
                                            <div class="fw-bold fs-5 mb-1">@SharedLocalizer["Confirm.DeleteAirport", airport.IATA ?? ""]</div>
                                            <p class="mb-0" style="color:var(--fo-muted);">@SharedLocalizer["Confirm.CannotUndo"]</p>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@SharedLocalizer["Btn.Cancel"]</button>
                                            <form asp-action="Delete" asp-route-id="@airport.Id" method="post" class="m-0">
                                                <button type="submit" class="btn btn-danger">@SharedLocalizer["Btn.Delete"]</button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
        @await Html.PartialAsync("Lists/_ListPagination")
        <p class="list-search-no-results d-none" data-fo-list-search-empty role="status">@SharedLocalizer["Search.NoResults"]</p>
    </div>
}
